# ─────────────────────────────────────────────────────────────────────────────
# Wardly model provider configuration
#
# The provider is auto-selected at runtime in priority order:
#   OLLAMA_BASE_URL > GROQ_API_KEY > GOOGLE_GENERATIVE_AI_API_KEY
# ─────────────────────────────────────────────────────────────────────────────

# RECOMMENDED for both local dev and Vercel deployment.
# Free key (no credit card): https://console.groq.com/keys
#
# Models used:
#   chat       → openai/gpt-oss-20b              (200k tokens/day, ~600ms TTFT)
#   synthesis  → meta-llama/llama-4-scout-17b   (separate quota, called once)
GROQ_API_KEY=

# Optional fallback. Used only if GROQ_API_KEY is unset.
# Free key: https://aistudio.google.com/apikey
# GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: truly local (no rate limits, slower on CPU). Won't work on Vercel.
# Install Ollama (https://ollama.com), then:
#   ollama pull qwen2.5:7b
#   ollama serve
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b
